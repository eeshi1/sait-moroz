<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Вход в систему | VOROBYEV.DEV</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-slate-950 text-white flex items-center justify-center h-screen px-6 relative overflow-hidden">
    <!-- Фоновые свечения -->
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-indigo-600/10 rounded-full blur-3xl"></div>

    <div class="bg-slate-900/60 backdrop-blur-xl p-8 rounded-3xl border border-slate-800 shadow-2xl w-full max-w-md relative z-10">
        <div class="text-center mb-8">
            <a href="/" class="text-2xl font-extrabold bg-gradient-to-r from-blue-400 to-indigo-400 bg-clip-text text-transparent tracking-tight">
                <i class="fa-solid fa-cubes-stacked mr-2"></i>VOROBYEV.DEV
            </a>
            <h1 class="text-xl font-bold text-slate-200 mt-4">Вход в панель управления</h1>
        </div>
        
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="bg-red-500/10 border border-red-500/20 text-red-400 px-4 py-3 rounded-xl mb-4 text-sm font-semibold flex items-center gap-2">
                <i class="fa-solid fa-circle-exclamation"></i> <%= error %>
            </div>
        <% } %>

        <form action="/login" method="POST" class="space-y-5">
            <div>
                <label class="block text-slate-400 font-semibold mb-1.5 text-sm">Логин</label>
                <input type="text" name="username" required placeholder="admin" class="w-full bg-slate-950/50 border border-slate-800 p-3 rounded-xl text-white focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10 transition">
            </div>
            <div>
                <label class="block text-slate-400 font-semibold mb-1.5 text-sm">Пароль</label>
                <input type="password" name="password" required placeholder="••••••••" class="w-full bg-slate-950/50 border border-slate-800 p-3 rounded-xl text-white focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10 transition">
            </div>
            <button type="submit" class="w-full bg-blue-600 text-white py-3.5 rounded-xl font-bold hover:bg-blue-500 transition shadow-lg shadow-blue-500/20 flex items-center justify-center gap-2">
                Войти <i class="fa-solid fa-right-to-bracket text-sm"></i>
            </button>
        </form>
        <p class="text-center text-sm text-slate-400 mt-6">
            Нет аккаунта? <a href="/register" class="text-blue-400 hover:underline font-semibold">Создать аккаунт</a>
        </p>
    </div>
</body>
</html>